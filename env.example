# Copia este fichero como ".env" y rellena tus claves reales.
# La app también puede leer estas variables si ya están exportadas en el entorno.

# Proveedor por defecto al arrancar la app: demo | fmp | polygon
SCREENER_PROVIDER=demo

# Financial Modeling Prep (fundamentales, estimaciones de analistas, sector PE)
FMP_API_KEY=

# Polygon.io (precios históricos ajustados de alta fiabilidad)
POLYGON_API_KEY=

# Ruta opcional de la base de datos SQLite (por defecto: ./screener.db)
SCREENER_DB_PATH=
